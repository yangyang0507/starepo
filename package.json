{
  "name": "starepo",
  "version": "1.1.1",
  "description": "Search your GitHub stars with semantic search",
  "type": "module",
  "bin": {
    "starepo": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yangyang0507/starepo.git"
  },
  "bugs": {
    "url": "https://github.com/yangyang0507/starepo/issues"
  },
  "homepage": "https://github.com/yangyang0507/starepo#readme",
  "author": "D.Yang <koyangslash@gmail.com>",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.22.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/auth-oauth-device": "^7.0.0",
    "@octokit/rest": "^21.0.0",
    "apache-arrow": "^18.1.0",
    "commander": "^12.0.0",
    "xdg-basedir": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "keywords": [
